# Copy this file to .env and fill in your values
# cp .env.example .env

# Server
PORT=5000
# NODE_ENV=production enables "secure" cookies (HTTPS-only)
NODE_ENV=development

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=buriad_huvtsas
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT Secret (use a long random string)
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# Public backend URL used by payment callbacks
SERVER_URL=http://localhost:5000

# QPay merchant credentials
# Leave empty for demo/mock payment mode
QPAY_BASE_URL=https://merchant-sandbox.qpay.mn/v2
QPAY_CLIENT_ID=
QPAY_CLIENT_SECRET=
QPAY_INVOICE_CODE=
# Optional override if QPay should call a URL different from SERVER_URL
QPAY_CALLBACK_URL=

# Virtual try-on proxy
TRYON_SPACE=yisol/IDM-VTON
TRYON_STEPS=30
TRYON_SEED=42
TRYON_MAX_IMAGE_BYTES=8388608
JSON_BODY_LIMIT=15mb
